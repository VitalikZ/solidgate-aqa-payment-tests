# Solidgate API credentials (provided by Solidgate)
SOLIDGATE_MERCHANT_ID=your_merchant_id_here
SOLIDGATE_SECRET_KEY=your_secret_key_here

# Optional overrides (defaults are sandbox URLs)
SOLIDGATE_API_BASE_URL=https://pay.solidgate.com/api/v1
SOLIDGATE_PAYMENT_PAGE_BASE_URL=https://payment-page.solidgate.com/api/v1
